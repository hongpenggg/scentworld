# Server-side secrets — set these in Vercel dashboard (Settings → Environment Variables)
# Do NOT use VITE_ prefix; these must never reach the browser bundle

OPENROUTER_API_KEY=your_openrouter_api_key_here
SITE_URL=https://your-deployment.vercel.app

# If switching back to Cloudflare Workers, use wrangler secret put OPENROUTER_API_KEY
